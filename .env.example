PORT=4001

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-to-at-least-32-characters-long
JWT_REFRESH_SECRET=change-me-to-at-least-32-characters-long
JWT_ADMIN_TTL=24h

# ─── MongoDB (current app runtime — Phase 2+ will add Prisma-backed paths) ───
MONGODB_URI=mongodb://127.0.0.1:27017/websankul

# ─── MySQL (Phase 1 migration — Docker ws-mysql on host port 3307) ───────────
MYSQL_ROOT_PASSWORD=websankul_dev
DATABASE_URL=mysql://root:websankul_dev@127.0.0.1:3307/websankul_staging

# Phase 2 — comma-separated modules that use MySQL (Prisma) instead of MongoDB
# Pilot: app-update,version (CMS singletons; reads staging dump row id=1)
MIGRATION_MYSQL_MODULES=app-update,version,faq

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6380

ENV=DEV
ORIGIN=http://localhost:4000

# ─── Migration API tests (docs/migration/api-tests) ─────────────────────────
# MIGRATION_API_BASE_URL=http://localhost:4001
# MIGRATION_TEST_ADMIN_EMAIL=admin@example.com
# MIGRATION_TEST_ADMIN_PASSWORD=your-password
# MIGRATION_TEST_CUSTOMER_PHONE=9999999999
# MIGRATION_TEST_CUSTOMER_OTP=5786
# MIGRATION_API_SKIP_WRITE=true   # set to skip PUT/POST/DELETE tests (default: run writes + revert)

# Copy remaining keys (SMTP, Razorpay, DO Spaces, etc.) from your existing .env as needed.
