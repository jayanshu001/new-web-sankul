<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Hind+Vadodara&display=swap');
    table, th { width: 100%; border-collapse: collapse; border: 0 solid black; font-family: Segoe UI, Hind Vadodara, sans-serif; }
    td, tr { overflow: hidden; border: 0 solid black; }
    td:nth-child(1) { width: 47%; text-align: left; }
    td:nth-child(2) { width: 6%;  text-align: center; }
    td:nth-child(3) { width: 47%; text-align: right; }
  </style>
</head>
<body>
  <div style="margin: 30px">
    <table>
      <tr style="font-size: 16px; vertical-align: top;">
        <td style="padding: 20px;">
          <div style="margin-bottom: 10px;"><%- include('../partials/logo') %></div>
          311, WebSankul, Shalin Galleria,<br>
          Complex, G-1 Circle, Near RTO,<br>
          Gandhinagar<br>
          GSTIN: 24AAGCN6700R1Z3<br>
          PAN: AAGCN6700R<br>
          CIN: U80900GJ2019PTC109756<br><br>
          <%= contactNumber %><br>
          <%= email %><br><br>
          Payment Method: <%= paymentMethod %><br>
          Payment Id: <%= razorpayPaymentId %><br>
        </td>
        <td></td>
        <td style="padding: 20px;">
          <div style="margin-bottom: 30px; font-size:30px">Pay Receipt</div>
          Receipt No : <%= receipt %><br>
          Date : <%= createdDate %><br>
          payer information :<br>
          <%= userName %><br>
          <%= userPhone %><br>
          <%= userEmailAddress %><br>
        </td>
      </tr>
      <tr style="background-color: #27a9e1; font-size:14px;">
        <td style="padding: 20px;">Item & Description</td>
        <td style="padding: 20px;">Validity</td>
        <td style="padding: 20px;">Amount</td>
      </tr>
      <% items.forEach(function(item) { %>
        <tr style="border-bottom: 0.5px solid #27a9e1; font-size:14px;">
          <td style="padding: 10px;"><%= item.name %></td>
          <td style="padding: 10px;"><%= item.validity %></td>
          <td style="padding: 10px;">₹ <%= item.amount %></td>
        </tr>
      <% }); %>
      <tr style="font-size:14px; border-top: 0.5px solid #27a9e1;">
        <td style="padding: 10px;"><b>Total</b></td>
        <td></td>
        <td style="padding: 10px;"><b>₹ <%= totalAmount %></b></td>
      </tr>
      <tr style="background-color: #e8e8e8; font-size:14px;">
        <td style="padding: 10px;"><b>Amount Received</b></td>
        <td></td>
        <td style="padding: 10px;"><b>₹ <%= totalAmount %></b></td>
      </tr>
      <tr style="border-bottom: 0.5px solid #27a9e1; font-size:14px;">
        <td style="padding: 10px;">Amount Received in Words :</td>
        <td></td>
        <td style="padding: 10px;"><%= totalAmountInWord %></td>
      </tr>
      <tr style="font-size:16px;">
        <td colspan="2" style="padding: 5px;">Notes:</td>
      </tr>
      <% notes.forEach(function(note) { %>
        <tr style="font-size:16px;">
          <td colspan="3" align="center" style="padding: 5px;"><%= note.list %></td>
        </tr>
      <% }); %>
    </table>
  </div>
</body>
</html>
